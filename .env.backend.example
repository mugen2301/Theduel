APP_NAME="The Duel ERP"
APP_ENV=production
APP_KEY=base64:replace_with_laravel_key
APP_DEBUG=false
APP_URL=https://api.theduel.in

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=theduel
DB_USERNAME=theduel
DB_PASSWORD=change_me_use_a_long_random_secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379

FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=theduel-production
AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

FRONTEND_URL=https://www.theduel.in
CUSTOMER_APP_URL=https://app.theduel.in
DEALER_APP_URL=https://dealer.theduel.in
ERP_APP_URL=https://erp.theduel.in
